msgid "Passwords do not match."
msgstr "Құпиясөздер сәйкес келмейді."

msgid "Invalid timezone. Use a valid IANA timezone name."
msgstr "Жарамсыз уақыт белдеуі. Дұрыс IANA атауын қолданыңыз."

msgid "Welcome to Blog API"
msgstr "Blog API жүйесіне қош келдіңіз"

msgid "Hi %(first_name)s,"
msgstr "Сәлем, %(first_name)s,"

msgid "Your account has been created successfully."
msgstr "Аккаунтыңыз сәтті құрылды."

msgid "You can now sign in and start using the API."
msgstr "Енді кіріп, API-ды пайдалана аласыз."

msgid "email"
msgstr "электрондық пошта"

msgid "first name"
msgstr "аты"

msgid "last name"
msgstr "тегі"

msgid "language"
msgstr "тіл"

msgid "timezone"
msgstr "уақыт белдеуі"

msgid "active"
msgstr "белсенді"

msgid "staff status"
msgstr "қызметкер мәртебесі"

msgid "date joined"
msgstr "тіркелген күні"

msgid "avatar"
msgstr "аватар"

msgid "This field is required."
msgstr "Бұл өріс міндетті."

msgid "Enter a valid email address."
msgstr "Дұрыс электрондық пошта мекенжайын енгізіңіз."

msgid "External services unavailable."
msgstr "Сыртқы сервистер қолжетімсіз."

msgid "Slug is required."
msgstr "Slug міндетті."
